        ],
        "operationId": "chatWebSocket",
        "summary": "WebSocket chat connection",
        "description": "This endpoint upgrades to a WebSocket connection. Clients send and receive ChatMessage JSON objects.",
        "security": [
          {
            "queryTokenAuth": []
          }
        ],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
