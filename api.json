  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "queryTokenAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "token"
      }
    },
    "responses": {
      "ErrorResponse": {
        "description": "GoFrame error response",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/GoFrameResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "GoFrameResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          },
          "data": true
        },
        "required": [
          "code",
          "message",
          "data"
        ],
        "additionalProperties": false
      },
      "EmailAuthRequest": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string"
          }
        },
        "required": [
          "access_token"
        ],
        "additionalProperties": false
      },
      "WechatAuthRequest": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          }
        },
        "required": [
          "code"
        ],
        "additionalProperties": false
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "user_info": {
            "$ref": "#/components/schemas/UserInfo"
          }
        },
        "required": [
          "token",
          "user_info"
        ],
        "additionalProperties": false
      },
      "WechatAuthResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/AuthResponse"
          },
          {
            "type": "object",
            "properties": {
              "openid": {
                "type": "string"
              }
            },
            "required": [
              "openid"
            ]
          }
        ]
      },
      "UserInfo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "uint64"
          },
          "openid": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "nickname": {
            "type": "string"
          },
          "avatar_url": {
            "type": "string"
          }
        },
        "required": [
          "id"
        ],
        "additionalProperties": false
      },
      "GetUserInfoResponse": {
        "type": "object",
        "properties": {
          "user_info": {
            "$ref": "#/components/schemas/UserInfo"
          }
        },
        "required": [
          "user_info"
        ],
        "additionalProperties": false
      },
      "UpdateUserInfoRequest": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "uint64"
          },
          "openid": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "nickname": {
            "type": "string"
          },
          "avatar_url": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "SupportedLanguage": {
        "type": "string",
        "enum": [
          "en",
          "zh-Hant",
          "zh-Hans"
        ]
      },
      "PrivacyMode": {
        "type": "string",
        "enum": [
          "private",
          "cloud_sync"
        ]
      },
      "UserSettings": {
        "type": "object",
        "properties": {
          "language": {
            "$ref": "#/components/schemas/SupportedLanguage"
          },
          "privacy_mode": {
            "$ref": "#/components/schemas/PrivacyMode"
          },
          "dream_reminder_enabled": {
            "type": "boolean"
          },
          "dream_reminder_time": {
            "type": "string"
          },
          "storage_mode": {
            "type": "string",
            "enum": [
              "local_cache",
              "cloud_sync"
            ]
          }
        },
        "required": [
          "language",
          "privacy_mode",
          "dream_reminder_enabled",
          "storage_mode"
        ],
        "additionalProperties": false
      },
      "UpdateUserSettingsRequest": {
        "$ref": "#/components/schemas/UserSettings"
      },
      "GetUserSettingsResponse": {
        "type": "object",
        "properties": {
          "user_settings": {
            "$ref": "#/components/schemas/UserSettings"
          }
        },
        "required": [
          "user_settings"
        ],
        "additionalProperties": false
      },
      "UpdateUserSettingsResponse": {
        "$ref": "#/components/schemas/GetUserSettingsResponse"
      },
      "PsycheProfile": {
        "type": "object",
        "properties": {
          "integration_score": {
            "type": "number"
          },
          "integration_level": {
